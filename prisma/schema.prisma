generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model cover_songs {
  id                String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  youtube_video_id  String           @unique
  vtuber_name       String
  channel_id        String
  video_title       String
  thumbnail_url     String
  published_at      DateTime         @db.Timestamptz(6)
  song_title        String
  artist_name       String
  spotify_track_id  String?
  spotify_track_url String?
  created_at        DateTime?        @default(now()) @db.Timestamptz(6)
  updated_at        DateTime?        @default(now()) @db.Timestamptz(6)
  user_favorites    user_favorites[]

  @@index([published_at(sort: Desc)], map: "idx_cover_songs_published_at")
  @@index([song_title], map: "idx_cover_songs_song_title")
  @@index([vtuber_name], map: "idx_cover_songs_vtuber_name")
  @@index([youtube_video_id], map: "idx_cover_songs_youtube_video_id")
}

model memories {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  channel_id String
  summary    String
  created_at DateTime? @default(now()) @db.Timestamptz(6)

  @@index([channel_id], map: "idx_memories_channel_id")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model monitored_channels {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  channel_id   String    @unique
  channel_name String
  is_active    Boolean?  @default(true)
  created_at   DateTime? @default(now()) @db.Timestamptz(6)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model user_favorites {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id       String      @db.Uuid
  cover_song_id String      @db.Uuid
  created_at    DateTime?   @default(now()) @db.Timestamptz(6)
  cover_songs   cover_songs @relation(fields: [cover_song_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, cover_song_id])
}

model Account {
  id                String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String  @db.Uuid
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionToken String   @unique @map("session_token")
  userId       String   @db.Uuid
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String?
  email         String?       @unique
  emailVerified DateTime?     @map("emailVerified")
  image         String?
  accounts      Account[]
  playHistory   PlayHistory[]
  sessions      Session[]

  @@map("users")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Track {
  id              String        @id
  name            String
  artist_name     String
  album_image_url String?
  playHistory     PlayHistory[]

  @@map("tracks")
}

model PlayHistory {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id     String   @db.Uuid
  track_id    String
  played_at   DateTime @db.Timestamptz(6)
  duration_ms Int
  track       Track    @relation(fields: [track_id], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, track_id, played_at])
  @@map("play_history")
}
